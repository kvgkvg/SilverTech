SILVERTECH_DB_PATH=apps/api/silvertech.sqlite3
SILVERTECH_STT_PROVIDER=mock
SILVERTECH_LLM_PROVIDER=mock
SILVERTECH_TEMPLATE_ROOT=data/templates
SILVERTECH_LOG_LEVEL=INFO
# Comma-separated origins of deployed frontends. Any localhost port is already
# allowed, so this is only needed once the web build is hosted somewhere.
SILVERTECH_CORS_ORIGINS=
# Required for POST/GET /api/admin/*. Unset means the admin router answers 503.
# Reviewing a submission writes the templates table the app serves from, so this
# must be set to a long random string whenever the API is reachable from outside.
SILVERTECH_ADMIN_TOKEN=
GOOGLE_STT_API_KEY=
ZALO_ASR_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
